{
  "name": "snaplive-watcher",
  "version": "1.0.0",
  "description": "SnapLive desktop folder watcher for photographers",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run compile && npx electron .",
    "compile": "npx tsc",
    "build": "npm run compile && npx electron-builder",
    "watch": "npx tsc --watch"
  },
  "build": {
    "appId": "com.snaplive.watcher",
    "productName": "SnapLive Watcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "node_modules/chokidar/**/*"
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "mac": {
      "category": "public.app-category.photography",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0"
  }
}